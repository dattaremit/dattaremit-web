{
  "name": "client-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "test": "jest",
    "semgrep": "semgrep scan --config=p/owasp-top-ten --config=p/secrets --config=p/react --config=p/typescript --config=p/jwt --config=.github/.semgrep.yml --error ."
  },
  "dependencies": {
    "@clerk/nextjs": "^6.39.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.50.0",
    "@tanstack/react-query": "^5.90.20",
    "axios": "^1.15.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.563.0",
    "motion": "^12.38.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-plaid-link": "^4.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "yup": "^1.7.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mts,mjs}": [
      "prettier --write",
      "eslint --fix",
      "bash -c 'command -v semgrep > /dev/null 2>&1 && semgrep --config=.github/.semgrep.yml --error || echo \"semgrep not installed — skipping local scan (CI will validate)\"'"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "knip": "^6.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
